{
	"name": "markdown-it-kbd-better",
	"version": "1.2.5",
	"description": "Markdown-it syntax add-on for the <kbd> tag, but with tiny improvements.",
	"author": "uncenter <hi@uncenter.dev>",
	"repository": "uncenter/markdown-it-kbd-better",
	"keywords": [
		"markdown-it",
		"markdown-it-plugin",
		"kbd"
	],
	"license": "MIT",
	"files": [
		"README.md",
		"LICENSE",
		"dist/"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"test": "vitest",
		"build": "tsdown",
		"lint": "biome lint .",
		"format": "biome check --write ."
	},
	"dependencies": {
		"markdown-it": "^13.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/markdown-it": "13.0.7",
		"@types/markdown-it-attrs": "^4.1.3",
		"markdown-it-attrs": "4.1.6",
		"tsdown": "^0.22.3",
		"typescript": "5.3.3",
		"vitest": "^1.1.1"
	},
	"engines": {
		"node": ">=18"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0 <12.0.0",
			"onFail": "error"
		}
	}
}
